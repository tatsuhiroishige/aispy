{
  "name": "aispy",
  "version": "0.1.0",
  "description": "AI Search Process Visualizer — MCP server + TUI that lets humans watch what AI is searching/reading on the web",
  "keywords": [
    "mcp",
    "ai",
    "search",
    "tui",
    "ink",
    "claude",
    "brave",
    "web-search",
    "terminal"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tatsuhiroishige/aispy"
  },
  "type": "module",
  "bin": {
    "aispy": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.19.0 || >=22.0.0"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "@mozilla/readability": "0.6.0",
    "axios": "1.15.0",
    "css-tree": "3.2.1",
    "dotenv": "17.4.1",
    "ink": "6.8.0",
    "jsdom": "27.0.1",
    "react": "19.2.5",
    "turndown": "7.2.4",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/css-tree": "2.3.11",
    "@types/jsdom": "28.0.1",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/turndown": "5.0.6",
    "eslint": "10.2.0",
    "ink-testing-library": "4.0.0",
    "prettier": "3.8.2",
    "tsx": "4.21.0",
    "typescript": "6.0.2",
    "typescript-eslint": "8.58.1",
    "vitest": "4.1.4"
  }
}
